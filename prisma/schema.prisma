generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model College {
  id          Int      @id @default(autoincrement())
  name        String
  location    String
  state       String
  fees        Int
  rating      Float
  courses     String[]
  placement   Int
  imageUrl    String?
  description String
  established Int
  createdAt   DateTime @default(now())
}